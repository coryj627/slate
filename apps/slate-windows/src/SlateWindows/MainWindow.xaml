<Window x:Class="SlateWindows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SlateWindows"
        Title="Slate"
        Height="720" Width="1120"
        MinHeight="480" MinWidth="760"
        UseLayoutRounding="True"
        AutomationProperties.AutomationId="Slate.MainWindow"
        Background="{DynamicResource Slate.WindowBackgroundBrush}"
        Foreground="{DynamicResource Slate.TextBrush}"
        PreviewKeyDown="Window_PreviewKeyDown"
        SourceInitialized="Window_SourceInitialized"
        Closing="Window_Closing"
        Closed="Window_Closed">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="WorkspaceTemplates.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control+Shift" Command="{Binding OpenVaultCommand}" />
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding QuickSwitcher.OpenCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding Workspace.SaveActiveCommand}" />
        <KeyBinding Key="W" Modifiers="Control" Command="{Binding Workspace.CloseActiveTabCommand}" />
        <KeyBinding Key="T" Modifiers="Control" Command="{Binding Workspace.DuplicateTabCommand}" />
        <KeyBinding Key="T" Modifiers="Control+Shift" Command="{Binding Workspace.ReopenClosedTabCommand}" />
        <KeyBinding Key="Oem5" Modifiers="Control" Command="{Binding Workspace.SplitRightCommand}" />
        <KeyBinding Key="Oem5" Modifiers="Control+Alt" Command="{Binding Workspace.SplitDownCommand}" />
        <KeyBinding Key="OemCloseBrackets" Modifiers="Control+Shift" Command="{Binding Workspace.NextTabCommand}" />
        <KeyBinding Key="OemOpenBrackets" Modifiers="Control+Shift" Command="{Binding Workspace.PreviousTabCommand}" />
        <KeyBinding Key="Left" Modifiers="Control+Alt" Command="{Binding Workspace.FocusPaneLeftCommand}" />
        <KeyBinding Key="Right" Modifiers="Control+Alt" Command="{Binding Workspace.FocusPaneRightCommand}" />
        <KeyBinding Key="Up" Modifiers="Control+Alt" Command="{Binding Workspace.FocusPaneAboveCommand}" />
        <KeyBinding Key="Down" Modifiers="Control+Alt" Command="{Binding Workspace.FocusPaneBelowCommand}" />
        <KeyBinding Key="Left" Modifiers="Control+Alt+Shift" Command="{Binding Workspace.MoveTabLeftCommand}" />
        <KeyBinding Key="Right" Modifiers="Control+Alt+Shift" Command="{Binding Workspace.MoveTabRightCommand}" />
        <KeyBinding Key="OemOpenBrackets" Modifiers="Control+Alt" Command="{Binding FileSidebar.HistoryBackCommand}" />
        <KeyBinding Key="OemCloseBrackets" Modifiers="Control+Alt" Command="{Binding FileSidebar.HistoryForwardCommand}" />
        <KeyBinding Key="OemPlus" Modifiers="Control+Alt" Command="{Binding Workspace.GrowPaneCommand}" />
        <KeyBinding Key="OemMinus" Modifiers="Control+Alt" Command="{Binding Workspace.ShrinkPaneCommand}" />
        <KeyBinding Key="I" Modifiers="Control+Alt" Command="{Binding Workspace.ToggleRightPaneCommand}" />
    </Window.InputBindings>

    <DockPanel>
        <Menu x:Name="MainMenu"
              DockPanel.Dock="Top">
            <Menu.Style>
                <Style TargetType="Menu">
                    <Setter Property="IsEnabled" Value="True" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding QuickSwitcher.IsOpen}" Value="True">
                            <Setter Property="IsEnabled" Value="False" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Menu.Style>
            <MenuItem Header="_File">
                <MenuItem Header="_Open Vault…"
                          AutomationProperties.AutomationId="OpenVaultMenuItem"
                          InputGestureText="Ctrl+Shift+O"
                          Command="{Binding OpenVaultCommand}" />
                <MenuItem Header="_Quick Open…"
                          AutomationProperties.AutomationId="QuickOpenMenuItem"
                          InputGestureText="Ctrl+O"
                          Click="QuickOpen_Click" />
                <Separator />
                <MenuItem Header="_Close Vault"
                          AutomationProperties.AutomationId="CloseVaultMenuItem"
                          Command="{Binding CloseVaultCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Command="{x:Static ApplicationCommands.Close}" />
            </MenuItem>
            <MenuItem Header="_Workspace">
                <MenuItem Header="_Duplicate Tab" InputGestureText="Ctrl+T" Command="{Binding Workspace.DuplicateTabCommand}" />
                <MenuItem Header="_Close Tab" InputGestureText="Ctrl+W" Command="{Binding Workspace.CloseActiveTabCommand}" />
                <MenuItem Header="_Reopen Closed Tab" InputGestureText="Ctrl+Shift+T" Command="{Binding Workspace.ReopenClosedTabCommand}" />
                <Separator />
                <MenuItem Header="Split _Right" AutomationProperties.AutomationId="SplitRightMenuItem" InputGestureText="Ctrl+\" Command="{Binding Workspace.SplitRightCommand}" />
                <MenuItem Header="Split _Down" AutomationProperties.AutomationId="SplitDownMenuItem" InputGestureText="Ctrl+Alt+\" Command="{Binding Workspace.SplitDownCommand}" />
                <MenuItem Header="Close _Pane" AutomationProperties.AutomationId="ClosePaneMenuItem" Command="{Binding Workspace.ClosePaneCommand}" />
                <Separator />
                <MenuItem Header="Focus Pane _Left" InputGestureText="Ctrl+Alt+Left" Command="{Binding Workspace.FocusPaneLeftCommand}" />
                <MenuItem Header="Focus Pane _Right" InputGestureText="Ctrl+Alt+Right" Command="{Binding Workspace.FocusPaneRightCommand}" />
                <MenuItem Header="Focus Pane _Above" InputGestureText="Ctrl+Alt+Up" Command="{Binding Workspace.FocusPaneAboveCommand}" />
                <MenuItem Header="Focus Pane _Below" InputGestureText="Ctrl+Alt+Down" Command="{Binding Workspace.FocusPaneBelowCommand}" />
                <MenuItem Header="Move Tab Left" InputGestureText="Ctrl+Alt+Shift+Left" Command="{Binding Workspace.MoveTabLeftCommand}" />
                <MenuItem Header="Move Tab Right" InputGestureText="Ctrl+Alt+Shift+Right" Command="{Binding Workspace.MoveTabRightCommand}" />
                <MenuItem Header="_Grow Pane" InputGestureText="Ctrl+Alt+=" Command="{Binding Workspace.GrowPaneCommand}" />
                <MenuItem Header="_Shrink Pane" InputGestureText="Ctrl+Alt+-" Command="{Binding Workspace.ShrinkPaneCommand}" />
                <Separator />
                <MenuItem Header="Toggle Right _Pane" InputGestureText="Ctrl+Alt+I" Command="{Binding Workspace.ToggleRightPaneCommand}" />
            </MenuItem>
            <MenuItem Header="_Files">
                <MenuItem Header="_Open" Command="{Binding FileSidebar.OpenCurrentCommand}" />
                <MenuItem Header="Open in New _Tab" Command="{Binding FileSidebar.OpenNewTabCommand}" />
                <MenuItem Header="Open in _Split" Command="{Binding FileSidebar.OpenSplitCommand}" />
                <Separator />
                <MenuItem Header="_Import Files and Folders…" Command="{Binding FileSidebar.ImportCommand}" />
                <MenuItem Header="_Cancel Import" Command="{Binding FileSidebar.CancelImportCommand}" />
                <Separator />
                <MenuItem Header="_Refresh" Command="{Binding FileSidebar.RefreshCommand}" />
                <MenuItem Header="_Collapse All" Command="{Binding FileSidebar.CollapseAllCommand}" />
                <MenuItem Header="_Expand Loaded" Command="{Binding FileSidebar.ExpandLoadedCommand}" />
                <MenuItem Header="Focus _Filter" InputGestureText="Ctrl+Alt+F" Click="FocusFilter_Click" />
                <MenuItem Header="_Back" InputGestureText="Ctrl+Alt+[" Command="{Binding FileSidebar.HistoryBackCommand}" />
                <MenuItem Header="_Forward" InputGestureText="Ctrl+Alt+]" Command="{Binding FileSidebar.HistoryForwardCommand}" />
                <Separator />
                <MenuItem Header="_Pin Note" Command="{Binding FileSidebar.PinCommand}" />
                <MenuItem Header="_Unpin Note" Command="{Binding FileSidebar.UnpinCommand}" />
                <MenuItem Header="Unpin _All in Folder" Command="{Binding FileSidebar.UnpinAllCommand}" />
                <MenuItem Header="Add to _Shortcuts" Command="{Binding FileSidebar.AddShortcutCommand}" />
                <MenuItem Header="_Remove Shortcut" Command="{Binding FileSidebar.RemoveShortcutCommand}" />
                <MenuItem Header="Use Vault Default _Sort" Command="{Binding FileSidebar.UseVaultDefaultSortCommand}" />
                <MenuItem Header="Clear _Recents" Command="{Binding FileSidebar.ClearRecentsCommand}" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock"
                           AutomationProperties.AutomationId="VaultStatus"
                           Text="{Binding StatusText}"
                           TextTrimming="CharacterEllipsis"
                           AutomationProperties.Name="Vault status" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem HorizontalContentAlignment="Stretch" Width="180">
                <ProgressBar Minimum="0"
                             AutomationProperties.AutomationId="VaultScanProgress"
                             Maximum="{Binding ProgressMaximum}"
                             Value="{Binding ProgressValue, Mode=OneWay}"
                             IsIndeterminate="{Binding IsProgressIndeterminate}"
                             Height="6"
                             AutomationProperties.Name="Vault scan progress" />
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid x:Name="WelcomeRoot"
                  Background="{DynamicResource Slate.WindowBackgroundBrush}"
                  AutomationProperties.AutomationId="WelcomeView"
                  Visibility="{Binding IsWelcomeVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                  FocusManager.FocusedElement="{Binding ElementName=OpenVaultButton}">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="IsEnabled" Value="True" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding QuickSwitcher.IsOpen}" Value="True">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36" />
                    <ColumnDefinition Width="520" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="1" Margin="0,56,0,32">
                    <TextBlock Text="Welcome to Slate" FontSize="30" FontWeight="SemiBold" AutomationProperties.HeadingLevel="Level1" />
                    <TextBlock Margin="0,8,0,24" FontSize="15" Foreground="{DynamicResource Slate.SecondaryTextBrush}" Text="Open a folder of Markdown files to start." />
                    <Button x:Name="OpenVaultButton"
                            AutomationProperties.AutomationId="OpenVaultButton"
                            Content="_Open Vault…"
                            Command="{Binding OpenVaultCommand}"
                            IsDefault="True"
                            HorizontalAlignment="Left"
                            Padding="16,8"
                            AutomationProperties.HelpText="Choose a folder to open as a Slate vault." />
                    <StackPanel Visibility="{Binding HasRecentVaults, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBlock Margin="0,32,0,8" FontSize="18" FontWeight="SemiBold" Text="Recent Vaults" AutomationProperties.HeadingLevel="Level2" />
                        <ItemsControl ItemsSource="{Binding RecentVaults}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,2"
                                            AutomationProperties.Name="{Binding DisplayName}"
                                            Padding="10,7"
                                            HorizontalContentAlignment="Left"
                                            Command="{Binding DataContext.OpenRecentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding Path}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Path}" FontSize="12" Foreground="{DynamicResource Slate.SecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid x:Name="WorkspaceRoot"
                  AutomationProperties.AutomationId="WorkspaceView"
                  Visibility="{Binding IsWorkspaceVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="IsEnabled" Value="True" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding QuickSwitcher.IsOpen}" Value="True">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Padding="12,8" Background="{DynamicResource Slate.RaisedSurfaceBrush}" BorderBrush="{DynamicResource Slate.BorderBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="{Binding VaultDisplayName}" FontSize="18" FontWeight="SemiBold" AutomationProperties.HeadingLevel="Level1" />
                        <TextBlock Text="{Binding VaultPath}" FontSize="12" Foreground="{DynamicResource Slate.SecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="270" MinWidth="200" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="*" MinWidth="300" />
                        <ColumnDefinition Width="5" />
                        <ColumnDefinition Width="280" MinWidth="200" />
                    </Grid.ColumnDefinitions>
                    <Border x:Name="FilesPaneBorder"
                            Grid.Column="0"
                            AutomationProperties.AutomationId="FilesPane"
                            Background="{DynamicResource Slate.SurfaceBrush}"
                            BorderBrush="{DynamicResource Slate.BorderBrush}"
                            BorderThickness="0,0,1,0"
                            DataContext="{Binding FileSidebar}">
                        <DockPanel Margin="10">
                            <StackPanel DockPanel.Dock="Top">
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="Files"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               AutomationProperties.HeadingLevel="Level2" />
                                    <Button DockPanel.Dock="Right"
                                            Padding="6,2"
                                            Content="↻"
                                            ToolTip="Refresh"
                                            AutomationProperties.Name="Refresh files"
                                            Command="{Binding RefreshCommand}" />
                                </DockPanel>
                                <TextBox x:Name="SidebarFilterTextBox"
                                         AutomationProperties.AutomationId="SidebarFilter"
                                         AutomationProperties.Name="Filter files"
                                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                         Padding="6,4"
                                         ToolTip="Filter by words, tag:, path:, or @date." />
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,6">
                                    <ComboBox Width="145"
                                              ItemsSource="{Binding SortModes}"
                                              SelectedItem="{Binding SortMode}"
                                              AutomationProperties.Name="File sort order">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource SidebarSortModeLabelConverter}}" />
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                    <CheckBox Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              Content="Group dates"
                                              IsChecked="{Binding GroupByDate}" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <ToggleButton Content="Tags"
                                                  IsChecked="{Binding ShowTags}"
                                                  AutomationProperties.Name="Show tag tree" />
                                    <ToggleButton Margin="6,0,0,0"
                                                  Content="Dual pane"
                                                  IsChecked="{Binding IsDualPaneEnabled}"
                                                  AutomationProperties.Name="Enable dual-pane files sidebar" />
                                </StackPanel>
                                <TreeView MaxHeight="120"
                                          ItemsSource="{Binding Tags}"
                                          ItemTemplate="{StaticResource SidebarTagTemplate}"
                                          SelectedItemChanged="Tags_SelectedItemChanged"
                                          Visibility="{Binding ShowTags, Converter={StaticResource BooleanToVisibilityConverter}}"
                                          AutomationProperties.AutomationId="SidebarTagTree"
                                          AutomationProperties.Name="Tags">
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem">
                                            <Setter Property="AutomationProperties.Name" Value="{Binding AutomationName}" />
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                </TreeView>
                            </StackPanel>
                            <StackPanel DockPanel.Dock="Bottom">
                                <TextBlock Margin="0,6,0,2"
                                           Text="{Binding BatchSelectionSummary}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Slate.SecondaryTextBrush}" />
                                <Expander Header="Batch actions" Margin="0,2">
                                    <StackPanel>
                                        <TextBox Text="{Binding TagInput, UpdateSourceTrigger=PropertyChanged}"
                                                 AutomationProperties.Name="Tag name" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button Content="Add" Command="{Binding AddTagCommand}" />
                                            <Button Margin="4,0,0,0" Content="Remove" Command="{Binding RemoveTagCommand}" />
                                        </StackPanel>
                                        <TextBox Margin="0,6,0,0"
                                                 Text="{Binding MoveDestination, UpdateSourceTrigger=PropertyChanged}"
                                                 AutomationProperties.Name="Move destination folder"
                                                 ToolTip="Vault-relative destination folder" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <Button Content="Move selected" Command="{Binding BatchMoveCommand}" />
                                            <Button Margin="4,0,0,0" Content="Trash selected" Command="{Binding BatchTrashCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Expander>
                                <Expander x:Name="SidebarFileActionsExpander"
                                          Header="File actions"
                                          Margin="0,2">
                                    <StackPanel>
                                        <TextBox x:Name="SidebarMutationNameTextBox"
                                                 Text="{Binding MutationName, UpdateSourceTrigger=PropertyChanged}"
                                                 PreviewKeyDown="SidebarMutationNameTextBox_PreviewKeyDown"
                                                 AutomationProperties.AutomationId="SidebarMutationName"
                                                 AutomationProperties.Name="File or folder name" />
                                        <WrapPanel Margin="0,4,0,0">
                                            <Button Content="New note" Command="{Binding CreateNoteCommand}" />
                                            <Button Margin="4,0,0,0" Content="New folder" Command="{Binding CreateFolderCommand}" />
                                            <Button Margin="4,0,0,0" Content="Rename" Command="{Binding RenameCommand}" />
                                            <Button Margin="4,0,0,0" Content="Delete" Command="{Binding DeleteCommand}" />
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4,0,0">
                                            <Button Content="Folder note" Command="{Binding CreateFolderNoteCommand}" />
                                            <Button Margin="4,0,0,0" Content="Delete folder note" Command="{Binding DeleteFolderNoteCommand}" />
                                            <Button Margin="4,0,0,0" Content="Copy link" Command="{Binding CopyWikilinkCommand}" />
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4,0,0">
                                            <Button Content="Open" Command="{Binding OpenCurrentCommand}" />
                                            <Button Margin="4,0,0,0" Content="New tab" Command="{Binding OpenNewTabCommand}" />
                                            <Button Margin="4,0,0,0" Content="Split" Command="{Binding OpenSplitCommand}" />
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4,0,0">
                                            <Button Content="Pin" Command="{Binding PinCommand}" />
                                            <Button Margin="4,0,0,0" Content="Unpin" Command="{Binding UnpinCommand}" />
                                            <Button Margin="4,0,0,0" Content="Add shortcut" Command="{Binding AddShortcutCommand}" />
                                        </WrapPanel>
                                        <WrapPanel Margin="0,4,0,0">
                                            <Button Content="Import…" Command="{Binding ImportCommand}" />
                                            <Button Margin="4,0,0,0" Content="Cancel import" Command="{Binding CancelImportCommand}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Expander>
                                <Expander Header="Shortcuts" Margin="0,2">
                                    <StackPanel>
                                        <ListBox MaxHeight="100"
                                                 ItemsSource="{Binding Shortcuts}"
                                                 SelectedItem="{Binding SelectedShortcut}"
                                                 DisplayMemberPath="DisplayName"
                                                 AutomationProperties.AutomationId="SidebarShortcuts"
                                                 AutomationProperties.Name="File shortcuts" />
                                        <Button Margin="0,4,0,0"
                                                HorizontalAlignment="Left"
                                                Content="Remove shortcut"
                                                Command="{Binding RemoveShortcutCommand}" />
                                    </StackPanel>
                                </Expander>
                                <TextBlock Margin="0,4,0,0"
                                           Text="{Binding Status}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Slate.SecondaryTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0">
                                    <TreeView x:Name="FilesTree"
                                              ItemsSource="{Binding RootNodes}"
                                              ItemTemplate="{StaticResource FileTreeNodeTemplate}"
                                              TextSearch.TextPath="DisplayName"
                                              SelectedItemChanged="FilesTree_SelectedItemChanged"
                                              Visibility="{Binding IsFilterActive, Converter={StaticResource InverseBooleanToVisibilityConverter}}"
                                              AutomationProperties.AutomationId="FilesTree"
                                              AutomationProperties.Name="Files">
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                                                <Setter Property="AutomationProperties.Name" Value="{Binding AutomationName}" />
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                    </TreeView>
                                    <ListBox x:Name="FilterResultsList"
                                             ItemsSource="{Binding FilterResults}"
                                             SelectionChanged="FilterResults_SelectionChanged"
                                             Visibility="{Binding IsFilterActive, Converter={StaticResource BooleanToVisibilityConverter}}"
                                             AutomationProperties.AutomationId="SidebarFilterResults"
                                             AutomationProperties.Name="Filtered files">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding DisplayName}" />
                                                    <TextBlock Text="{Binding Path}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource Slate.SecondaryTextBrush}" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Grid>
                                <ListBox Grid.Row="1"
                                         MaxHeight="150"
                                         Margin="0,6,0,0"
                                         ItemsSource="{Binding DualPaneFiles}"
                                         SelectionChanged="DualPaneFiles_SelectionChanged"
                                         DisplayMemberPath="DisplayName"
                                         Visibility="{Binding IsDualPaneEnabled, Converter={StaticResource BooleanToVisibilityConverter}}"
                                         AutomationProperties.AutomationId="SidebarDualPane"
                                         AutomationProperties.Name="Files in selected folder" />
                            </Grid>
                        </DockPanel>
                    </Border>
                    <GridSplitter Grid.Column="1"
                                  Background="{DynamicResource Slate.BorderBrush}"
                                  HorizontalAlignment="Stretch"
                                  ResizeDirection="Columns"
                                  AutomationProperties.Name="Resize files sidebar" />
                    <Border x:Name="ContentPaneBorder"
                            Grid.Column="2"
                            AutomationProperties.AutomationId="ContentPane"
                            Background="{DynamicResource Slate.WindowBackgroundBrush}"
                            DataContext="{Binding Workspace}">
                        <ContentControl Content="{Binding Root}"
                                        ContentTemplate="{StaticResource WorkspaceNodeTemplate}"
                                        GotKeyboardFocus="WorkspaceContent_GotKeyboardFocus"
                                        AutomationProperties.Name="Workspace editor panes" />
                    </Border>
                    <GridSplitter Grid.Column="3"
                                  Background="{DynamicResource Slate.BorderBrush}"
                                  HorizontalAlignment="Stretch"
                                  ResizeDirection="Columns"
                                  AutomationProperties.Name="Resize right pane" />
                    <Border Grid.Column="4"
                            AutomationProperties.AutomationId="InspectorPane"
                            Background="{DynamicResource Slate.SurfaceBrush}"
                            BorderBrush="{DynamicResource Slate.BorderBrush}"
                            BorderThickness="1,0,0,0"
                            DataContext="{Binding Workspace}"
                            Visibility="{Binding IsRightPaneVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="92" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="12">
                                <TextBlock Text="{Binding ActiveLeaf.Title}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           AutomationProperties.HeadingLevel="Level2" />
                                <TextBlock Margin="0,8,0,0"
                                           Text="This panel is docked and ready for its feature surface."
                                           Foreground="{DynamicResource Slate.SecondaryTextBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <ListBox x:Name="RightPaneLeavesList"
                                     Grid.Column="1"
                                     ItemsSource="{Binding LeafOptions}"
                                     SelectedItem="{Binding ActiveLeaf, Mode=TwoWay}"
                                     DisplayMemberPath="Title"
                                     AutomationProperties.AutomationId="RightPaneLeaves"
                                     AutomationProperties.Name="Right pane panels" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
            <!-- A full-window hit-test layer makes Quick Open modal for pointer
                 input. The underlying shell is disabled above, so UIA clients
                 cannot invoke commands behind the visible overlay either. -->
            <Border Background="Transparent"
                    Visibility="{Binding QuickSwitcher.IsOpen, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Border x:Name="QuickSwitcherOverlay"
                    Width="600"
                    MaxHeight="430"
                    Padding="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,72,0,0"
                    Background="{DynamicResource Slate.SurfaceBrush}"
                    BorderBrush="{DynamicResource Slate.BorderBrush}"
                    BorderThickness="1"
                    Visibility="{Binding QuickSwitcher.IsOpen, Converter={StaticResource BooleanToVisibilityConverter}}"
                    DataContext="{Binding QuickSwitcher}"
                    FocusManager.IsFocusScope="True"
                    KeyboardNavigation.TabNavigation="Cycle"
                    KeyboardNavigation.ControlTabNavigation="Cycle"
                    AutomationProperties.AutomationId="QuickSwitcher"
                    AutomationProperties.Name="Quick Open"
                    AutomationProperties.IsDialog="True">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.28" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="QuickSwitcherSearchTextBox"
                                 Grid.Column="0"
                                 Padding="10,8"
                                 FontSize="18"
                                 Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewKeyDown="QuickSwitcherSearch_PreviewKeyDown"
                                 AutomationProperties.AutomationId="QuickSwitcherSearch"
                                 AutomationProperties.Name="Search files"
                                 AutomationProperties.HelpText="Up and Down move selection. Enter opens. Control Enter opens a new tab. Control Alt Enter opens a split. Escape closes Quick Open." />
                        <Button Grid.Column="1"
                                Margin="8,0,0,0"
                                Padding="10,4"
                                Content="Close"
                                Command="{Binding DismissCommand}"
                                AutomationProperties.AutomationId="QuickSwitcherClose"
                                AutomationProperties.Name="Close Quick Open" />
                    </Grid>
                    <ListBox x:Name="QuickSwitcherResultsList"
                             Grid.Row="1"
                             Margin="0,8"
                             ItemsSource="{Binding Results}"
                             SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                             MouseDoubleClick="QuickSwitcherResults_MouseDoubleClick"
                             AutomationProperties.AutomationId="QuickSwitcherResults"
                             AutomationProperties.Name="Quick Open results">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="AutomationProperties.Name" Value="{Binding DisplayName}" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Path}"
                                               Foreground="{DynamicResource Slate.SecondaryTextBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <DockPanel Grid.Row="2">
                        <TextBlock Text="{Binding ResultSummary}"
                                   Foreground="{DynamicResource Slate.SecondaryTextBrush}" />
                        <TextBlock DockPanel.Dock="Right"
                                   Text="Enter open · Ctrl+Enter tab · Ctrl+Alt+Enter split · Esc close"
                                   Foreground="{DynamicResource Slate.SecondaryTextBrush}" />
                    </DockPanel>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
