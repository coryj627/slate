<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Provisional W1 palette. Text-bearing pairs are intentionally high
         separation; W8-2 owns final values and the permanent APCA gate. -->
    <Color x:Key="Slate.WindowBackgroundColor">#FFF7F7F7</Color>
    <Color x:Key="Slate.SurfaceColor">#FFFFFFFF</Color>
    <Color x:Key="Slate.RaisedSurfaceColor">#FFEFEFEF</Color>
    <Color x:Key="Slate.TextColor">#FF171717</Color>
    <Color x:Key="Slate.SecondaryTextColor">#FF3A3A3A</Color>
    <Color x:Key="Slate.BorderColor">#FF767676</Color>
    <Color x:Key="Slate.AccentColor">#FF005A9E</Color>
    <Color x:Key="Slate.SelectionBackgroundColor">#FF004578</Color>
    <Color x:Key="Slate.SelectionTextColor">#FFFFFFFF</Color>
    <Color x:Key="Slate.ErrorColor">#FF8A0014</Color>

    <SolidColorBrush x:Key="Slate.WindowBackgroundBrush"
                     Color="{StaticResource Slate.WindowBackgroundColor}" />
    <SolidColorBrush x:Key="Slate.SurfaceBrush"
                     Color="{StaticResource Slate.SurfaceColor}" />
    <SolidColorBrush x:Key="Slate.RaisedSurfaceBrush"
                     Color="{StaticResource Slate.RaisedSurfaceColor}" />
    <SolidColorBrush x:Key="Slate.TextBrush"
                     Color="{StaticResource Slate.TextColor}" />
    <SolidColorBrush x:Key="Slate.SecondaryTextBrush"
                     Color="{StaticResource Slate.SecondaryTextColor}" />
    <SolidColorBrush x:Key="Slate.BorderBrush"
                     Color="{StaticResource Slate.BorderColor}" />
    <SolidColorBrush x:Key="Slate.AccentBrush"
                     Color="{StaticResource Slate.AccentColor}" />
    <SolidColorBrush x:Key="Slate.SelectionBackgroundBrush"
                     Color="{StaticResource Slate.SelectionBackgroundColor}" />
    <SolidColorBrush x:Key="Slate.SelectionTextBrush"
                     Color="{StaticResource Slate.SelectionTextColor}" />
    <SolidColorBrush x:Key="Slate.FocusBrush"
                     Color="{StaticResource Slate.AccentColor}" />
    <SolidColorBrush x:Key="Slate.ErrorBrush"
                     Color="{StaticResource Slate.ErrorColor}" />
    <SolidColorBrush x:Key="Slate.EditorHeadingBrush"
                     Color="{StaticResource Slate.AccentColor}" />
    <SolidColorBrush x:Key="Slate.EditorCodeBrush"
                     Color="{StaticResource Slate.SecondaryTextColor}" />
    <SolidColorBrush x:Key="Slate.EditorWikilinkBrush"
                     Color="{StaticResource Slate.AccentColor}" />
    <SolidColorBrush x:Key="Slate.EditorTagBrush"
                     Color="{StaticResource Slate.AccentColor}" />
    <SolidColorBrush x:Key="Slate.EditorMetadataBrush"
                     Color="{StaticResource Slate.SecondaryTextColor}" />
</ResourceDictionary>
