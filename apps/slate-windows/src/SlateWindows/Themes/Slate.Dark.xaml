<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Provisional W1 palette; W8-2 owns final values and APCA CI. -->
    <Color x:Key="Slate.WindowBackgroundColor">#FF121212</Color>
    <Color x:Key="Slate.SurfaceColor">#FF1E1E1E</Color>
    <Color x:Key="Slate.RaisedSurfaceColor">#FF292929</Color>
    <Color x:Key="Slate.TextColor">#FFF5F5F5</Color>
    <Color x:Key="Slate.SecondaryTextColor">#FFD4D4D4</Color>
    <Color x:Key="Slate.BorderColor">#FFAAAAAA</Color>
    <Color x:Key="Slate.AccentColor">#FFB9D9FF</Color>
    <Color x:Key="Slate.SelectionBackgroundColor">#FFB9D9FF</Color>
    <Color x:Key="Slate.SelectionTextColor">#FF101010</Color>
    <Color x:Key="Slate.ErrorColor">#FFFFD1D6</Color>

    <SolidColorBrush x:Key="Slate.WindowBackgroundBrush"
                     Color="{StaticResource Slate.WindowBackgroundColor}" />
    <SolidColorBrush x:Key="Slate.SurfaceBrush"
                     Color="{StaticResource Slate.SurfaceColor}" />
    <SolidColorBrush x:Key="Slate.RaisedSurfaceBrush"
                     Color="{StaticResource Slate.RaisedSurfaceColor}" />
    <SolidColorBrush x:Key="Slate.TextBrush"
                     Color="{StaticResource Slate.TextColor}" />
    <SolidColorBrush x:Key="Slate.SecondaryTextBrush"
                     Color="{StaticResource Slate.SecondaryTextColor}" />
    <SolidColorBrush x:Key="Slate.BorderBrush"
                     Color="{StaticResource Slate.BorderColor}" />
    <SolidColorBrush x:Key="Slate.AccentBrush"
                     Color="{StaticResource Slate.AccentColor}" />
    <SolidColorBrush x:Key="Slate.SelectionBackgroundBrush"
                     Color="{StaticResource Slate.SelectionBackgroundColor}" />
    <SolidColorBrush x:Key="Slate.SelectionTextBrush"
                     Color="{StaticResource Slate.SelectionTextColor}" />
    <SolidColorBrush x:Key="Slate.FocusBrush"
                     Color="{StaticResource Slate.AccentColor}" />
    <SolidColorBrush x:Key="Slate.ErrorBrush"
                     Color="{StaticResource Slate.ErrorColor}" />
</ResourceDictionary>
